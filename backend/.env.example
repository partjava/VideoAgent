APP_NAME=video-agent-backend
APP_ENV=development

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=video_agent
MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000

MODEL_PROVIDER=deepseek
IMAGE_PROVIDER=qwen
VIDEO_PROVIDER=wan

DEEPSEEK_PROVIDER=deepseek
QWEN_IMAGE_PROVIDER=qwen
WAN_VIDEO_PROVIDER=wan

# DeepSeek Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
ENABLE_PAID_API=false
DEEPSEEK_MODEL=deepseek-v4-flash

# DashScope Configuration
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
MAX_IMAGES_PER_TASK=10
MAX_VIDEO_SECONDS_PER_TASK=30
MAX_DYNAMIC_SCENES_PER_TASK=3
WAN_VIDEO_MODEL=wan2.7-i2v-2026-04-25
WANX_IMAGE_MODEL=wan2.7-image

# ComfyUI Configuration
# Use IMAGE_PROVIDER=comfyui and/or VIDEO_PROVIDER=comfyui after the workflow mapping is configured.
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_SECONDS=300
